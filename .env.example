# Database
DATABASE_URL="postgresql://user:password@localhost:5432/loscalo?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Resend Email
RESEND_API_KEY="your-resend-api-key"
EMAIL_MODE="send"  # 'send' per inviare email, 'save-only' per salvare in test-emails/

# Stripe (modalità test/sandbox)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_tua_chiave_pubblica"
STRIPE_SECRET_KEY="sk_test_tua_chiave_segreta"
STRIPE_WEBHOOK_SECRET="whsec_tua_chiave_webhook"

# Stripe Dashboard URL (per link ai pagamenti da admin)
# Test: https://dashboard.stripe.com/acct_XXXXX/test/payments/
# Live: https://dashboard.stripe.com/acct_XXXXX/payments/
NEXT_PUBLIC_STRIPE_DASHBOARD_URL="https://dashboard.stripe.com/acct_XXXXX/test/payments/"
