# Rate Limiting Configuration (Opzionale)
# Se non specificati, vengono usati i valori di default

# API Pubbliche (creazione ordini, cancellazione)
# Default: 2 richieste per minuto
# Nessuno fa più di 3 ordini in 60 secondi legittimamente
# RATE_LIMIT_PUBLIC_API=2
# RATE_LIMIT_PUBLIC_WINDOW=60

# API Admin (operazioni sensibili: rimborsi, creazione GC, etc.)
# Default: 100 richieste per minuto
# RATE_LIMIT_ADMIN_API=100
# RATE_LIMIT_ADMIN_WINDOW=60

# Webhook Stripe (molto permissivo)
# Default: 1000 richieste per minuto
# RATE_LIMIT_WEBHOOK=1000
# RATE_LIMIT_WEBHOOK_WINDOW=60

# Auth (login) - anti brute force
# Default: 5 tentativi per minuto
# RATE_LIMIT_AUTH=5
# RATE_LIMIT_AUTH_WINDOW=60

# Disabilita completamente il rate limiting (solo per sviluppo/testing)
# RATE_LIMITING_ENABLED=false
