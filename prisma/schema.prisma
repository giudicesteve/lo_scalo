generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}

model Admin {
  id                   String   @id @default(cuid())
  email                String   @unique
  name                 String?
  image                String?
  receiveNotifications Boolean  @default(true)
  canManageAdmins      Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Category {
  id               String     @id @default(cuid())
  nameIt           String
  nameEn           String
  macroCategoryIt  String?
  macroCategoryEn  String?
  showAlcoholLevel Boolean    @default(true)
  order            Int        @default(0)
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  cocktails        Cocktail[]
}

model Cocktail {
  id            String   @id @default(cuid())
  nameIt        String
  nameEn        String
  ingredientsIt String?
  ingredientsEn String?
  descriptionIt String?
  descriptionEn String?
  price         Int      // Prezzo in cents (es: 1250 = €12.50)
  alcoholLevel  Int?
  isActive      Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
}

model GiftCardTemplate {
  id        String   @id @default(cuid())
  value     Int      // Valore in cents (es: 5000 = €50.00)
  price     Int      // Prezzo in cents (es: 5000 = €50.00)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GiftCard {
  id             String                @id @default(cuid())
  code           String                @unique
  initialValue   Int                   // Valore iniziale in cents
  remainingValue Int                   // Valore residuo in cents
  isActive       Boolean               @default(true)
  isArchived     Boolean               @default(false)
  purchasedAt    DateTime              @default(now())
  activatedAt    DateTime?
  expiresAt      DateTime?
  orderId        String
  isExpired      Boolean               @default(false)
  order          Order                 @relation(fields: [orderId], references: [id])
  transactions   GiftCardTransaction[]
  
  // Soft delete per rimborso
  isSoftDeleted  Boolean               @default(false)
  deletedAt      DateTime?
  deletedBy      String?               // Admin ID
  deletionNote   String?
  refundId       String?               // Riferimento al rimborso
  refund         Refund?               @relation(fields: [refundId], references: [id])
}

model GiftCardTransaction {
  id            String   @id @default(cuid())
  amount        Int      // Importo in cents
  type          String
  note          String?
  createdAt     DateTime @default(now())
  giftCardId    String
  receiptImage  String?
  receiptNumber String?
  giftCard      GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
}

model GiftCardExpiryConfig {
  id         String             @id @default("gift-card-expiry")
  expiryType GiftCardExpiryType @default(END_OF_MONTH)
  expiryTime GiftCardExpiryTime @default(ONE_YEAR)
  updatedAt  DateTime           @updatedAt
}

model Order {
  id                    String      @id @default(cuid())
  orderNumber           String      @unique
  type                  String
  status                String      @default("PENDING_PAYMENT")
  email                 String
  phone                 String?
  total                 Int         // Totale in cents
  customerName          String?
  stripePaymentId       String?
  stripePaymentIntentId String?
  isArchived            Boolean     @default(false)
  emailSent             Boolean     @default(false)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  lang                  String      @default("it")
  paidAt                DateTime?
  isHidden              Boolean     @default(false)
  orderSource           OrderSource @default(ONLINE)
  giftCards             GiftCard[]
  items                 OrderItem[]
  refunds               Refund[]    // Rimborsi associati all'ordine
}

model OrderItem {
  id             String          @id @default(cuid())
  quantity       Int
  unitPrice      Int             // Prezzo unitario in cents
  totalPrice     Int             // Prezzo totale in cents
  size           String?
  orderId        String
  productId      String
  variantId      String?
  productName    String?         // Nome del prodotto in italiano (snapshot)
  productNameEn  String?         // Nome del prodotto in inglese (snapshot)
  refundedQuantity Int           @default(0) // Quantità già rimborsata
  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  Product        Product         @relation(fields: [productId], references: [id])
  ProductVariant ProductVariant? @relation(fields: [variantId], references: [id])
}

model Product {
  id             String           @id @default(cuid())
  name           String           // Nome in italiano
  nameEn         String?          // Nome in inglese (opzionale)
  descriptionIt  String
  descriptionEn  String
  price          Int              // Prezzo in cents
  image          String
  hasSizes       Boolean          @default(true)
  isActive       Boolean          @default(true)
  isDeleted      Boolean          @default(false)
  deletedAt      DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  OrderItem      OrderItem[]
  ProductVariant ProductVariant[]
}

model PolicyDocument {
  id            String             @id @default(cuid())
  type          PolicyType
  version       String
  isActive      Boolean            @default(false)
  effectiveDate DateTime
  createdAt     DateTime           @default(now())
  createdBy     String?
  isArchived    Boolean            @default(false)
  contentIt     String
  contentEn     String
  acceptances   PolicyAcceptance[]

  @@index([type, isActive])
  @@index([type, isArchived])
}

model PolicyAcceptance {
  id         String         @id @default(cuid())
  policyId   String
  email      String
  ipAddress  String?
  acceptedAt DateTime       @default(now())
  orderId    String
  policy     PolicyDocument @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([email])
}

model ProductVariant {
  id        String      @id
  size      String
  quantity  Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime
  productId String
  OrderItem OrderItem[]
  Product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
}

enum GiftCardExpiryType {
  EXACT_DATE
  END_OF_MONTH
}

enum GiftCardExpiryTime {
  SIX_MONTHS
  ONE_YEAR
  TWO_YEARS
}

enum OrderSource {
  ONLINE
  MANUAL
}

enum PolicyType {
  TERMS
  PRIVACY
  COOKIES
}

// Modello per la gestione rimborsi
model Refund {
  id            String   @id @default(cuid())
  
  // Riferimento all'ordine originale
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  
  // Numero rimborso (formato: RIM-YYYY-XXXX-RAND)
  refundNumber  String   @unique
  
  // Item rimborsati (dettagli completi per storico)
  // Esempio: [{ type: 'PRODUCT', productId: '...', name: 'Maglietta', size: 'XL', price: 25.00, quantity: 1 },
  //           { type: 'GIFT_CARD', giftCardId: '...', code: 'GC-ABC123', value: 50.00 }]
  items         Json
  
  // Totale rimborsato
  totalRefunded Int  // In cents
  
  // Metadati
  reason        String?
  notes         String?
  
  // Chi ha fatto il rimborso
  refundedBy    String   // Admin ID
  refundedAt    DateTime @default(now())
  
  // Metodo rimborso
  refundMethod  RefundMethod // STRIPE, CASH, POS
  externalRef   String?      // Stripe refund ID o numero scontrino rimborso
  
  // Flag per reportistica
  isArchived    Boolean  @default(false)
  
  // Relazione con gift card rimborsate
  giftCards     GiftCard[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([orderId])
  @@index([refundedAt])
}

enum RefundMethod {
  STRIPE
  CASH
  POS
}
