# Cache Configuration (Opzionale)
# Se non specificati, vengono usati i valori di default

# ============================================
# CATEGORIE (Menu)
# Default: 300s (5 minuti) / stale-while-revalidate: 3600s (1 ora)
# ============================================
# CACHE_CATEGORIES_TTL=300
# CACHE_CATEGORIES_STALE=3600

# ============================================
# PRODOTTI (Shop)
# Default: 60s (1 minuto) / stale-while-revalidate: 300s (5 minuti)
# Nota: Basso TTL perché lo stock può cambiare
# ============================================
# CACHE_PRODUCTS_TTL=60
# CACHE_PRODUCTS_STALE=300

# ============================================
# GIFT CARD TEMPLATES
# Default: 300s (5 minuti) / stale-while-revalidate: 3600s (1 ora)
# ============================================
# CACHE_GIFT_CARDS_TTL=300
# CACHE_GIFT_CARDS_STALE=3600

# ============================================
# FEATURE FLAGS
# Default: 60s (1 minuto) / stale-while-revalidate: 300s (5 minuti)
# Nota: Basso TTL perché i toggle possono cambiare
# ============================================
# CACHE_FEATURE_FLAGS_TTL=60
# CACHE_FEATURE_FLAGS_STALE=300

# ============================================
# POLICY (Termini, Privacy, Cookie)
# Default: 300s (5 minuti)
# Nota: Solo client-side cache (CDN non cached)
# ============================================
# CACHE_POLICIES_TTL=300
